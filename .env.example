# Base URL path of the Astro site
BASE_URL=https://summerisvolley.it/

# Hostname of the PHP server hosting the SIV hub pages
PUBLIC_PHP_SERVER_HOST=https://hub.summerisvolley.it/

# Gallery Photo Source Configuration (local or gcs)
GALLERY_SOURCE=local

# Google Cloud Storage Configuration (Required if GALLERY_SOURCE=gcs)
GCS_BUCKET_NAME=siv-photos-bucket
GCS_THUMBS_FOLDER=thumbs
GCS_THUMBS_NESTED=true
GCS_PRIVATE_BUCKET=false
GCS_LARGE_WIDTH=1200
GCS_LARGE_HEIGHT=800
GCS_THUMB_SUFFIX=_400x400.webp
GCS_LARGE_SUFFIX=_1200x800.webp

# Optional: Base64-encoded service account JSON key (required if GCS buckets are not publicly listable)
# GCP_SERVICE_ACCOUNT_KEY=

