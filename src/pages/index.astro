---
import "../styles/global.css";
import BaseLayout from "../layouts/BaseLayout.astro";
import Sponsors from "../components/Sponsors.astro";
import Button from "../components/Button.astro";

const menu = [
    {
        title: "Galleria",
        href: "/galleria",
    },
    {
        title: "Gare",
        href: "/",
    },
    {
        title: "Classifica",
        href: "/",
    },
    {
        title: "Fasi finali",
        href: "/",
    },
];
---

<BaseLayout>
    <div class="container mx-auto flex flex-col items-center justify-center">
        <div class="mt-20 grid grid-cols-1 md:grid-cols-2 justify-center align-middle gap-4">
            {menu.map((item) => (
                    <Button value={item.title} href={item.href}/>
            ))}
        </div>
    </div>

    <Sponsors/>
</BaseLayout>