---
import EmptyLayout from "../layouts/EmptyLayout.astro";
---
<EmptyLayout>
    <div class="flex flex-col items-center justify-center min-h-screen px-4 py-12 text-center bg-radial from-slate-900 to-black text-white">
        <div class="max-w-2xl flex flex-col items-center">
            <img src="/logo.png" alt="SIV Logo" class="w-72 md:w-96 p-8 drop-shadow-[0_0_15px_rgba(113,172,236,0.3)] animate-pulse duration-[3000ms]" />
            
            <h1 class="font-miskan text-4xl md:text-6xl text-siv-yellow mb-2 tracking-wide uppercase">
                Coming Soon
            </h1>
            
            <div class="w-24 h-1 bg-siv-blue rounded-full mb-8"></div>
            
            <div class="text-base md:text-lg text-slate-300 font-light max-w-lg mb-8 leading-relaxed italic text-center space-y-4">
                <p>
                    Le iscrizioni al <strong>Summer Is Volley 2026</strong> sono aperte! <br> Clicca sul pulsante qui sotto per accedere al portale e registrare la tua squadra.
                </p>
            </div>
            
            <a href="https://play.summerisvolley.it/" target="_blank" rel="noopener noreferrer" class="group relative px-8 py-4 bg-siv-yellow text-slate-950 font-bold text-xl md:text-2xl rounded-full shadow-[0_0_20px_rgba(255,225,61,0.3)] hover:shadow-[0_0_30px_rgba(255,225,61,0.5)] hover:scale-105 active:scale-95 transition-all duration-300 ease-out font-miskan flex items-center gap-3">
                Iscriviti Ora
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6 transition-transform duration-300 group-hover:translate-x-1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
            </a>
        </div>
    </div>
</EmptyLayout>