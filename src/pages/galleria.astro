---
import {Picture} from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import type {ImageMetadata} from "astro";
import EmptyGallery from "../components/EmptyGallery.astro";

const matches = import.meta.glob(
    "/src/assets/gallery/**/*.{jpeg,jpg,png,JPG}",
    {eager: true},
) as Record<string, { default: ImageMetadata }>;

// Group images by the day they were taken, assuming the folder structure is like:
// /src/assets/gallery/YYYY-MM-DD/image.jpg
const matchesGroupedByDay = Object.groupBy(
    Object.entries(matches),
    ([path, _mod]) => path.split("/")[4],
);

// Convert grouped entries to a more usable format and sort by date (newest first)
const imagesGroupedByDay = Object.entries(matchesGroupedByDay)
    .map(
        ([date, entries]) =>
            [
                date as string,
                entries!.map(([_, mod]) => mod.default as ImageMetadata),
            ] as [string, ImageMetadata[]],
    )
    .sort((a, b) => new Date(b[0]).getTime() - new Date(a[0]).getTime());
---

<BaseLayout title="Galleria Foto | Summer Is Volley">
    <!-- Sticky Gallery Navigation/Filter Header -->
    <div class="sticky top-20 z-40 bg-surface/85 backdrop-blur-xl border-b border-outline-variant/20 shadow-md">
        <div class="flex flex-col items-center justify-center py-4">
            <label for="date-filter" class="text-xs font-bold uppercase tracking-wider text-on-surface-variant mb-1 font-label-bold">
                Vai alla data:
            </label>
            <div class="flex items-center rounded-lg bg-surface-container/60 px-3 border border-outline-variant/30 focus-within:border-tertiary focus-within:shadow-[0_0_15px_rgba(0,219,233,0.15)] transition-all duration-300">
                <select id="date-filter" class="block w-full border-0 py-2 pr-8 text-on-surface text-sm bg-transparent outline-none cursor-pointer font-body-md">
                    <option class="bg-surface-container text-on-surface" value="top">Inizio pagina</option>
                    {
                        imagesGroupedByDay.map(([date]) => (
                            <option class="bg-surface-container text-on-surface" value={date}>
                                {new Date(date).toLocaleDateString("it-IT", {
                                    year: "numeric",
                                    month: "long",
                                    day: "numeric",
                                })}
                            </option>
                        ))
                    }
                </select>
            </div>
        </div>
    </div>

    <div class="relative overflow-hidden pt-8 pb-20 min-h-[60vh] bg-mesh">
        <!-- Background Blur Blobs -->
        <div class="absolute inset-0 z-0 pointer-events-none">
            <div class="absolute top-1/3 left-10 w-96 h-96 bg-primary/10 rounded-full blur-[140px]"></div>
            <div class="absolute bottom-1/3 right-10 w-96 h-96 bg-tertiary/5 rounded-full blur-[140px]"></div>
        </div>

        <div class="relative z-10 max-w-[1280px] mx-auto px-6">

            <!-- Display a message if no images are found -->
            {Object.entries(matches).length === 0 && <EmptyGallery />}

            <!-- Display the images in a grid with PhotoSwipe -->
            <div id="gallery" class="space-y-16 pt-16">
                {
                    imagesGroupedByDay.map(([date, images]) => (
                        <div class="day-section scroll-mt-36" data-date={date}>
                            <div class="flex items-center gap-3 mb-6 px-2">
                                <span class="material-symbols-outlined text-primary text-2xl">calendar_today</span>
                                <h2 class="font-headline-md text-xl md:text-2xl text-on-surface font-bold">
                                    {new Date(date).toLocaleDateString("it-IT", {
                                        year: "numeric",
                                        month: "long",
                                        day: "numeric",
                                    })}
                                </h2>
                                <div class="flex-1 h-px bg-outline-variant/20 ml-4 hidden sm:block"></div>
                            </div>
                            
                            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
                                {images.map(async (image) => {
                                    return (
                                        <a
                                            href={image.src}
                                            data-pswp-width={image.width}
                                            data-pswp-height={image.height}
                                            target="_blank"
                                            class="block overflow-hidden rounded-xl border border-outline-variant/10 hover:border-primary/50 shadow-lg hover:shadow-primary/5 hover:scale-[1.03] transition-all duration-300 group aspect-square bg-surface-container"
                                        >
                                            <Picture
                                                src={image}
                                                alt={`SIV Match Image - ${date}`}
                                                width={600}
                                                quality={65}
                                                formats={["avif", "webp"]}
                                                class="object-cover w-full object-top aspect-square group-hover:scale-105 transition-transform duration-500"
                                                loading="lazy"
                                            />
                                        </a>
                                    );
                                })}
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>

    <!-- Floating Back to Top Button -->
    <button
        id="back-to-top"
        class="fixed bottom-6 right-6 z-50 w-12 h-12 bg-secondary-container text-on-secondary-container rounded-full shadow-2xl transition-all duration-300 hover:bg-secondary-fixed hover:scale-110 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 opacity-0 translate-y-10 pointer-events-none flex items-center justify-center cursor-pointer border border-secondary-container/20 group"
        aria-label="Torna all'inizio"
    >
        <span class="material-symbols-outlined text-2xl font-bold group-hover:-translate-y-0.5 transition-transform">arrow_upward</span>
    </button>
</BaseLayout>

<script>
    import { initPhotoSwipe } from "../scripts/photoswipe";
    import { initGalleryNav } from "../scripts/gallery-nav";

    initPhotoSwipe();
    initGalleryNav();
</script>
