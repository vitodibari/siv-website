---
import {Image, getImage} from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import type {ImageMetadata} from "astro";

const matches = import.meta.glob("/src/assets/gallery/*.{jpeg,jpg,png,JPG}", {eager: true}) as
    Record<string, { default: ImageMetadata; }>;
const images = Object.values(matches).map((image) => image.default)
---

<BaseLayout>
    {
        images.length === 0 && (
                    <div class="mx-auto flex flex-col items-center justify-center gap-8 mt-32">
                        <p class="text-xl">Nessuna immagine trovata</p>
                        <p class="text-xs">
                            E fatemele fare prima 🙃
                            <br>
                            -VDB
                        </p>
                    </div>
        )
    }
    <div id="gallery" class="container mx-auto px-2 pb-2 grid grid-cols-3 md:grid-cols-4 gap-1">
        {
            images.map(async (image) => {
                const optimizedImage = await getImage({
                    src: image,
                });

                return (
                        <a
                                href={optimizedImage.src}
                                data-pswp-width={optimizedImage.attributes.width}
                                data-pswp-height={optimizedImage.attributes.height}
                                target="_blank"
                        >
                            <Image
                                    src={image}
                                    alt={image.src}
                                    width={1000}
                                    quality={25}
                                    class="object-cover w-full object-top aspect-square"
                                    loading="lazy"
                            />
                        </a>

                );
            })
        }
    </div>
</BaseLayout>

<script>
    import PhotoSwipeLightbox from "photoswipe/lightbox";
    import "photoswipe/style.css";

    const lightbox = new PhotoSwipeLightbox({
        gallery: "#gallery",
        children: "a",
        pswpModule: () => import("photoswipe"),
    });

    lightbox.init();
</script>