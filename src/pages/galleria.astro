---
import {Picture} from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import type {ImageMetadata} from "astro";
import EmptyGallery from "../components/EmptyGallery.astro";

const matches = import.meta.glob(
    "/src/assets/gallery/**/*.{jpeg,jpg,png,JPG}",
    {eager: true},
) as Record<string, { default: ImageMetadata }>;

// Group images by the day they were taken, assuming the folder structure is like:
// /src/assets/gallery/YYYY-MM-DD/image.jpg
const matchesGroupedByDay = Object.groupBy(
    Object.entries(matches),
    ([path, _mod]) => path.split("/")[4],
);

// Convert grouped entries to a more usable format and sort by date (newest first)
const imagesGroupedByDay = Object.entries(matchesGroupedByDay)
    .map(
        ([date, entries]) =>
            [
                date as string,
                entries!.map(([_, mod]) => mod.default as ImageMetadata),
            ] as [string, ImageMetadata[]],
    )
    .sort((a, b) => new Date(b[0]).getTime() - new Date(a[0]).getTime());
---

<BaseLayout>
    <div class="sticky top-0 z-10 bg-white/80 backdrop-blur-md border-b border-gray-100">
        <div class="flex flex-col items-center justify-center py-4">
            <label for="date-filter" class="text-sm font-medium text-gray-500 mb-1">Vai alla data:</label>
            <div class="flex items-center rounded-md bg-white px-3 shadow-sm ring-1 ring-inset ring-gray-300 focus-within:ring-2 focus-within:ring-blue-600">
                <select id="date-filter" class="block w-full border-0 py-1.5 text-gray-900 focus:ring-0 sm:text-sm sm:leading-6 bg-transparent outline-none">
                    <option value="top">Inizio pagina</option>
                    {
                        imagesGroupedByDay.map(([date]) => (
                                <option value={date}>
                                    {new Date(date).toLocaleDateString("it-IT", {
                                        year: "numeric",
                                        month: "long",
                                        day: "numeric",
                                    })}
                                </option>
                        ))
                    }
                </select>
            </div>
        </div>
    </div>

    <!--Display a message if no images are found-->
    {Object.entries(matches).length === 0 &&
            <EmptyGallery/>}

    <!--Display the images in a grid with PhotoSwipe-->
    <div id="gallery" class="container mx-auto px-2 pb-2">
        {
            imagesGroupedByDay.map(([date, images]) => (
                    <div class="day-section mb-12 scroll-mt-24" data-date={date}>
                        <h2 class="text-2xl font-bold mb-6 px-2">
                            {new Date(date).toLocaleDateString("it-IT", {
                                year: "numeric",
                                month: "long",
                                day: "numeric",
                            })}
                        </h2>
                        <div class="grid grid-cols-3 md:grid-cols-4 gap-1">
                            {images.map(async (image) => {
                                return (
                                        <a
                                                href={image.src}
                                                data-pswp-width={image.width}
                                                data-pswp-height={image.height}
                                                target="_blank"
                                                class="hover:opacity-90 transition-opacity"
                                        >
                                            <Picture
                                                    src={image}
                                                    alt={image.src}
                                                    width={1000}
                                                    quality={50}
                                                    formats={["avif", "webp"]}
                                                    class="object-cover w-full object-top aspect-square rounded-sm"
                                                    loading="lazy"
                                            />
                                        </a>
                                );
                            })}
                        </div>
                    </div>
            ))
        }
    </div>

    <!-- Floating Back to Top Button -->
    <button
            id="back-to-top"
            class="fixed bottom-6 right-6 z-50 p-3 bg-blue-600 text-white rounded-full shadow-lg opacity-0 translate-y-10 transition-all duration-300 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 pointer-events-none"
            aria-label="Torna all'inizio"
    >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
        </svg>
    </button>
</BaseLayout>

<script>
    import { initPhotoSwipe } from "../scripts/photoswipe";
    import { initGalleryNav } from "../scripts/gallery-nav";

    initPhotoSwipe();
    initGalleryNav();
</script>
