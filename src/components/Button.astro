---
interface Props {
    value: string;
    href: string;
    target?: string;
    disabled?: boolean;
}

const {value, href, target = '', disabled = false} = Astro.props;
---

<a href={href} target={target}>
    <button class=`bg-siv-blue text-2xl md:text-3xl font-bold border-0 w-36 md:w-60 h-20 md:h-32 ${disabled ? 'opacity-50' : 'cursor-pointer active:bg-siv-yellow hover:text-white'}`
            disabled={disabled}>
        {value}
    </button>
</a>
