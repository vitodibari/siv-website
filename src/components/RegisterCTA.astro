<section class="py-32 relative overflow-hidden z-10">
    <!-- Skewed Gradient Background -->
    <div class="absolute inset-0 bg-primary/5 -skew-y-3 transform origin-right pointer-events-none"></div>
    
    <div class="relative z-10 max-w-4xl mx-auto text-center px-6">
        <h2 class="font-headline-lg text-3xl md:text-5xl text-on-surface mb-8 uppercase tracking-tight">
            Pronti a Conquistare il Vostro Posto al Sole?
        </h2>
        <p class="font-body-lg text-base md:text-xl text-on-surface-variant mb-12 max-w-2xl mx-auto leading-relaxed">
            Non lasciatevi sfuggire il torneo dell'anno. Le iscrizioni per la stagione 2026 sono aperte per tutte le categorie. Registrate la vostra squadra oggi stesso!
        </p>
        
        <!-- Gradient Border Showcase CTA Button -->
        <div class="inline-block p-0.5 bg-gradient-to-r from-primary via-tertiary to-secondary-container rounded-2xl hover:scale-105 transition-transform duration-300 shadow-[0_0_40px_rgba(157,49,255,0.15)] group">
            <a 
                href="https://hub.summerisvolley.it" 
                class="block px-12 py-5 bg-background rounded-[14px] font-headline-md text-lg md:text-xl text-on-surface font-bold hover:bg-transparent hover:text-on-primary transition-all duration-300"
            >
                ISCRIVI LA TUA SQUADRA
            </a>
        </div>
    </div>
</section>
