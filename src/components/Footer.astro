---
import { PHP_PATHS } from "../consts";
import VDB from "./VDB.astro";
import { getCleanUrl } from "../utils";
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL || '';
---

<footer class="w-full py-8 bg-surface-container-lowest border-t border-outline-variant/10 z-10 relative">
    <div class="flex flex-col md:flex-row justify-between gap-12 px-6 max-w-[1280px] mx-auto text-center md:text-left">
        <div>
            <h3 class="font-headline-md text-2xl font-black text-primary text-glow-primary mb-4">Summer Is Volley</h3>
            <p class="font-body-md text-sm text-on-surface-variant leading-relaxed">
                Summer Is Volley è il torneo di pallavolo organizzato da A.S.D. Iuno a Sammichele di Bari.
            </p>
        </div>
        <!--<div class="flex flex-col gap-3">-->
        <!--    <h4 class="font-label-bold text-xs text-on-surface mb-3 uppercase tracking-widest font-bold">Menu Rapido</h4>-->
        <!--    <a class="text-sm text-on-surface-variant hover:text-on-surface transition-colors" href={base}>Home</a>-->
        <!--    <a class="text-sm text-on-surface-variant hover:text-on-surface transition-colors" href={`${base}galleria`}>Galleria</a>-->
        <!--    <a class="text-sm text-on-surface-variant hover:text-on-surface transition-colors" href={PHP_PATHS.CALENDARI}>Calendario</a>-->
        <!--    <a class="text-sm text-on-surface-variant hover:text-on-surface transition-colors" href={PHP_PATHS.CLASSIFICA}>Classifiche</a>-->
        <!--</div>-->
        <div class="flex flex-col gap-4">
            <div class="flex items-center justify-center md:justify-start gap-3">
                <h4 class="font-label-bold text-xs text-on-surface uppercase tracking-widest font-bold">Seguici</h4>
                <a 
                    class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center text-on-surface-variant hover:bg-primary hover:text-on-primary transition-all duration-300" 
                    href="https://www.instagram.com/summerisvolley/" 
                    target="_blank" 
                    aria-label="Instagram"
                >
                    <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
