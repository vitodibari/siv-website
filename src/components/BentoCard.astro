---
interface Props {
    title: string;
    description: string;
    href: string;
    icon: string;
    color?: 'primary' | 'secondary' | 'tertiary';
    disabled?: boolean;
}

const {
    title,
    description,
    href,
    icon,
    color = 'primary',
    disabled = false,
} = Astro.props;

// Determine theme styling for icons and states based on color prop
const colorClasses = {
    primary: 'bg-primary/10 text-primary',
    secondary: 'bg-secondary-container/10 text-secondary-fixed',
    tertiary: 'bg-tertiary/10 text-tertiary',
};

const hoverBorderClasses = {
    primary: 'hover:border-primary/50 hover:bg-primary/5 hover:shadow-[0_0_30px_rgba(220,184,255,0.15)]',
    secondary: 'hover:border-secondary-container/50 hover:bg-secondary-container/5 hover:shadow-[0_0_30px_rgba(255,225,109,0.15)]',
    tertiary: 'hover:border-tertiary/50 hover:bg-tertiary/5 hover:shadow-[0_0_30px_rgba(0,219,233,0.15)]',
};

const Tag = disabled ? 'div' : 'a';
---

<Tag 
    href={disabled ? undefined : href} 
    class={`glass-card p-4 sm:p-6 md:p-8 rounded-2xl flex flex-col items-center justify-center text-center ${
        disabled 
            ? 'opacity-60 border-dashed cursor-not-allowed select-none' 
            : `group cursor-pointer ${hoverBorderClasses[color]}`
    }`}
>
    <div class={`w-12 h-12 md:w-16 md:h-16 rounded-xl flex items-center justify-center mb-4 md:mb-6 ${
        disabled 
            ? 'bg-surface-container-high text-outline' 
            : `transition-transform duration-300 group-hover:scale-110 ${colorClasses[color]}`
    }`}>
        <span class="material-symbols-outlined text-2xl md:text-4xl">{icon}</span>
    </div>
    <h3 class={`font-headline-md text-sm md:text-xl mb-1 md:mb-2 ${disabled ? 'text-outline' : 'text-on-surface'}`}>
        {title}
    </h3>
    <p class={`font-body-md text-xs md:text-sm ${disabled ? 'text-outline' : 'text-on-surface-variant leading-relaxed'}`}>
        {description}
    </p>
</Tag>
