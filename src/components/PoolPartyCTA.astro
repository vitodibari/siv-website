---

<section class="relative overflow-hidden pt-24 pb-8 z-10">
    {/* Clean gradient background effect for pool party */}
    <div class="absolute inset-0 bg-primary/5 -skew-y-3 transform origin-right pointer-events-none"></div>
    
    <div class="relative z-10 max-w-4xl mx-auto text-center px-6">
        <span class="text-4xl md:text-5xl mb-3 block">🏊</span>
        <h2 class="font-headline-lg text-3xl md:text-5xl text-on-surface mb-4 font-black uppercase tracking-tight">
            SIV Closing Pool Party 2026
        </h2>
        <p class="font-body-lg text-base md:text-lg text-on-surface-variant mb-8 max-w-xl mx-auto leading-relaxed">
            <span class="text-sm font-semibold mt-2 block text-primary">
              Giocatori SIV: 7€ • Esterni: 15€ • Pagamenti validi da lunedì mattina a mercoledì sera
            </span>
        </p>
        
        {/* Dynamic CTA button */}
        <div class="inline-block p-0.5 bg-gradient-to-r from-sky-400 via-blue-500 to-teal-400 rounded-2xl hover:scale-105 transition-transform duration-300 shadow-[0_0_30px_rgba(56,189,248,0.25)] group">
            <a 
                href="https://play.summerisvolley.it/pool-party-landing" 
                class="block px-10 py-4 bg-background rounded-[14px] font-headline-md text-base md:text-lg text-on-surface font-bold hover:bg-transparent hover:text-white transition-all duration-300"
            >
                ISCRIVITI ORA AL POOL PARTY
            </a>
        </div>
    </div>
</section>
