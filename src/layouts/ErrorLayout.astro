---
import {SITE_DESCRIPTION, SITE_TITLE} from "../consts";
import BaseHead from "../components/BaseHead.astro";

interface Props {
    errorCode: string;
    errorMsg: string;
}

const {errorCode, errorMsg} = Astro.props;
---

<html lang="en">
<head>
    <BaseHead/>
</head>
<body>
<div class="h-screen flex flex-col justify-center items-center align-middle text-center">
    <img src="/logo.png" class="w-40 m-5">
    <span class="font-orbitron-bold mb-5">
        {errorCode}
        <br>
        {errorMsg}
    </span>
    <a href="/" class="font-orbitron-regular underline hover:text-red">Homepage</a>
</div>
</body>
</html>
